{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  },
  "AzureAd": {
    "Authority": "https://login.microsoftonline.com/your-tenant-id",
    "Audience": "api://your-client-id"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 200
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 5000
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/identity/{**catch-all}" }
        ]
      },
      "content-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/content/{**catch-all}"
        }
      },
      "documents-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/documents/{**catch-all}"
        }
      },
      "search-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        }
      },
      "collaboration-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/collaboration/{**catch-all}"
        }
      },
      "media-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/media/{**catch-all}"
        }
      },
      "workflow-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/workflow/{**catch-all}"
        }
      },
      "calendar-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/calendar/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "ai-route": {
        "ClusterId": "webapi-cluster",
        "Match": {
          "Path": "/api/ai/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "webapi-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5010/"
          }
        },
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:10",
            "Policy": "ConsecutiveFailures",
            "Path": "/health/live"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{RequestId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
